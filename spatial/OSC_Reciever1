import time
import threading
from pythonosc import dispatcher, osc_server, udp_client

# Reaper's OSC listener (set this up in Reaper's OSC settings)
reaper = udp_client.SimpleUDPClient("10.90.158.3", 8000)


osc_input = -0.1    # normalized -1 to 1 (direction + speed)
position = 0.0       # output value, loops between -1 and 1
lock = threading.Lock()
stop_event = threading.Event()

TICK = 0.01          # loop resolution in seconds (10ms)
MAX_STEP = 0.1       # how much position changes at full speed per tick

def speed_handler(address, value):
    global osc_input
    with lock:
        osc_input = max(-1.0, min(1.0, float(value)))  # clamp to -1..1

def counter():
    global position
    while not stop_event.is_set():
        with lock:
            val = osc_input

        if abs(val) > 0.01:  # dead zone
            step = val * MAX_STEP  # sign = direction, magnitude = speed
            position += step

            # wrap between -1 and 1
            if position > 1.0:
                position -= 1.0
            elif position < 0.0:
                position += 1.0

            reaper.send_message("/track/6/fx/1/fxparam/4/value", position) # send value to reaper 
            print(f"{position:.4f}")

        time.sleep(TICK)



# commands in kernel for controlling the system 
def start():
    stop_event.clear()
    threading.Thread(target=counter, daemon=True).start()

def stop():
    stop_event.set()

def reset():
    global position
    position = 0.0

# Set up OSC
d = dispatcher.Dispatcher()
d.map("/control/roll", speed_handler)

server = osc_server.ThreadingOSCUDPServer(("10.90.158.3", 6677), d)
threading.Thread(target=server.serve_forever, daemon=True).start()

print("Ready. Call start() and stop() to control.")

def shutdown():
    stop()
    server.shutdown()
    print("Stopped counter and closed OSC port.")
